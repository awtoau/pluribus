BLOCK RESETPATHS;
BLOCK ASYNCPATHS;

LOCATE COMP "clk" SITE "63";
IOBUF PORT "clk" IO_TYPE=LVCMOS33;

LOCATE COMP "d" SITE "62";
IOBUF PORT "d" IO_TYPE=LVCMOS33;

LOCATE COMP "q_rise" SITE "59";
IOBUF PORT "q_rise" IO_TYPE=LVCMOS33;

LOCATE COMP "q_fall" SITE "58";
IOBUF PORT "q_fall" IO_TYPE=LVCMOS33;

FREQUENCY PORT "clk" 100.000000 MHz;
