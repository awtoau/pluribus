BLOCK RESETPATHS;
BLOCK ASYNCPATHS;

LOCATE COMP "clk" SITE "88";
IOBUF PORT "clk" IO_TYPE=LVCMOS33;

LOCATE COMP "pad_p" SITE "97";
IOBUF PORT "pad_p" IO_TYPE=LVDS25;

LOCATE COMP "pad_n" SITE "96";
IOBUF PORT "pad_n" IO_TYPE=LVDS25;

LOCATE COMP "out0" SITE "84";
IOBUF PORT "out0" IO_TYPE=LVCMOS33;

FREQUENCY PORT "clk" 100.000000 MHz;
