BLOCK RESETPATHS;
BLOCK ASYNCPATHS;

LOCATE COMP "clk" SITE "88";
IOBUF PORT "clk" IO_TYPE=LVCMOS33;

LOCATE COMP "d" SITE "87";
IOBUF PORT "d" IO_TYPE=LVCMOS33;

LOCATE COMP "out0" SITE "84";
IOBUF PORT "out0" IO_TYPE=LVCMOS33;

FREQUENCY PORT "clk" 100.000000 MHz;

SYSCONFIG SDM_PORT=DISABLE SLAVE_SPI_PORT=ENABLE BACKGROUND_RECONFIG=OFF ;
